{
  "name": "sd-dev",
  "image": "twint/sd:latest",
  "initializeCommand": "xhost +local:root",
  "features": {},
  "runArgs": [
    "--net=host",
    "--ipc=host",
    "--env=DISPLAY=${localEnv:DISPLAY}",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix"
  ],
  "containerEnv": {
    "WINIT_UNIX_BACKEND": "x11",
    "WAYLAND_DISPLAY": ""
  },
  "remoteEnv": {
    "WINIT_UNIX_BACKEND": "x11",
    "WAYLAND_DISPLAY": ""
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "twint.hdl-studio",
        "mshr-h.veriloghdl",
        "surfer-project.surfer"
      ]
    }
  }
}